# BRDS-PEC Configuration Template
# Copy this file to '.env' and fill in your values.

# Containment Mode: Set to 0 to enable live process-killing/network-disabling.
# Set to 1 (default) for safe logging-only dry-runs.
BRDS_DRY_RUN=1

# API Authentication key for the live telemetry ingestion endpoint (e.g. random 32-char hex string)
BRDS_API_KEY=your_secure_api_ingestion_key_here

# Secret key used to sign and verify the integrity of local JSON alerts
BRDS_ALERT_HMAC_KEY=your_secure_alert_hmac_key_here

# Permitted cross-origin hosts allowed to read the Flask API (comma-separated list)
BRDS_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
